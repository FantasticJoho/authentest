{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start API Only",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				".\\AuthTest.Api",
				"--urls",
				"http://localhost:5000"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Start WebForms Only (IIS Express)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& 'C:\\Program Files\\IIS Express\\iisexpress.exe' /path:'${workspaceFolder}\\AuthTest.Web' /port:8081 /clr:v4.0"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Start AuthTest Dev (API + IIS Express)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".\\start-dev.ps1"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Start AuthTest Dev (No Build)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".\\start-dev.ps1",
				"-SkipWebBuild"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Stop AuthTest Dev (API + IIS Express)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".\\stop-dev.ps1"
			],
			"group": "build"
		}
	]
}